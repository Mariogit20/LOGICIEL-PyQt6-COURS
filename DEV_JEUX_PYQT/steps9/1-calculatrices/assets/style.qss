QMainWindow {
    background: qlineargradient(
        x1: 0, y1: 0,    /* début du gradient (coin haut-gauche) */
        x2: 1, y2: 1,    /* fin du gradient (coin bas-droit) */
        stop: 0 #141e30, /* couleur de départ */
        stop: 1 #243b55  /* couleur de fin */
    );
}

/* ============================= */
/* Écran calculatrice */
/* ============================= */
QLineEdit[class="calculator-display"] {
    background-color: #0f2027;
    color: white;
    border: none;
    border-radius: 10px;
    padding: 10px;
    font-size: 24px;
}

/* ============================= */
/* Boutons standard */
/* ============================= */
QPushButton[class="calculator-button"] {
    background-color: rgba(255, 255, 255, 0.08);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 18px;
}

/* Hover */
QPushButton[class="calculator-button"]:hover {
    background-color: rgba(255, 255, 255, 0.15);
}

/* Click */
QPushButton[class="calculator-button"]:pressed {
    background-color: rgba(255, 255, 255, 0.25);
}
